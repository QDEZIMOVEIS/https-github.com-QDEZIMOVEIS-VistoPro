{
  "entities": {
    "User": {
      "title": "User",
      "description": "The user profile information.",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "displayName": { "type": "string" },
        "email": { "type": "string" },
        "photoURL": { "type": "string" },
        "role": { "type": "string", "enum": ["inspector", "admin"] }
      },
      "required": ["uid", "email"]
    },
    "Property": {
      "title": "Property",
      "description": "A property being inspected.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "address": { "type": "string" },
        "ownerName": { "type": "string" },
        "tenantName": { "type": "string" },
        "inspectorId": { "type": "string" },
        "price": { "type": "number" },
        "size": { "type": "number" },
        "bedrooms": { "type": "number" },
        "bathrooms": { "type": "number" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["address", "inspectorId"]
    },
    "Favorite": {
      "title": "Favorite",
      "description": "A property favorited by a user.",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "propertyId": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["userId", "propertyId"]
    },
    "Inspection": {
      "title": "Inspection",
      "description": "An inspection report for a property.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "propertyId": { "type": "string" },
        "type": { "type": "string", "enum": ["Entry", "Exit", "Periodic"] },
        "status": { "type": "string", "enum": ["Draft", "Completed"] },
        "date": { "type": "string", "format": "date-time" },
        "inspectorId": { "type": "string" }
      },
      "required": ["propertyId", "type", "status", "inspectorId"]
    },
    "Room": {
      "title": "Room",
      "description": "A room within an inspection.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "inspectionId": { "type": "string" },
        "name": { "type": "string" },
        "order": { "type": "number" }
      },
      "required": ["inspectionId", "name"]
    },
    "Item": {
      "title": "Item",
      "description": "An item within a room to be inspected.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "roomId": { "type": "string" },
        "name": { "type": "string" },
        "status": { "type": "string", "enum": ["Good", "Regular", "Bad", "N/A"] },
        "notes": { "type": "string" },
        "photos": { "type": "array", "items": { "type": "string" } }
      },
      "required": ["roomId", "name", "status"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "User",
      "description": "User profiles."
    },
    "/properties/{propertyId}": {
      "schema": "Property",
      "description": "Properties managed by inspectors."
    },
    "/inspections/{inspectionId}": {
      "schema": "Inspection",
      "description": "Inspection reports."
    },
    "/rooms/{roomId}": {
      "schema": "Room",
      "description": "Rooms in an inspection."
    },
    "/items/{itemId}": {
      "schema": "Item",
      "description": "Items in a room."
    },
    "/favorites/{favoriteId}": {
      "schema": "Favorite",
      "description": "User favorite properties."
    }
  }
}
