rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // ===============================================================
    // Assumed Data Model
    // ===============================================================
    //
    // Collection: users
    // Document ID: {userId}
    // Fields:
    //   - uid: string (required)
    //   - displayName: string (optional)
    //   - email: string (required)
    //   - photoURL: string (optional)
    //   - role: string (required, enum: ["inspector", "admin"])
    //
    // Collection: properties
    // Document ID: {propertyId}
    // Fields:
    //   - id: string (required)
    //   - address: string (required)
    //   - ownerName: string (optional)
    //   - tenantName: string (optional)
    //   - inspectorId: string (required)
    //   - createdAt: timestamp (required)
    //
    // Collection: inspections
    // Document ID: {inspectionId}
    // Fields:
    //   - id: string (required)
    //   - propertyId: string (required)
    //   - type: string (required, enum: ["Entry", "Exit", "Periodic"])
    //   - status: string (required, enum: ["Draft", "Completed"])
    //   - date: timestamp (required)
    //   - inspectorId: string (required)
    //
    // Collection: rooms
    // Document ID: {roomId}
    // Fields:
    //   - id: string (required)
    //   - inspectionId: string (required)
    //   - name: string (required)
    //   - order: number (required)
    //   - notes: string (optional)
    //   - media: list (optional)
    //
    // Collection: items
    // Document ID: {itemId}
    // Fields:
    //   - id: string (required)
    //   - roomId: string (required)
    //   - name: string (required)
    //   - status: string (required, enum: ["Good", "Regular", "Bad", "N/A"])
    //   - notes: string (optional)
    //   - photos: list (optional)
    //
    // ===============================================================

    // ===============================================================
    // Helper Functions
    // ===============================================================
    
    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    function isInspector(inspectorId) {
      return isAuthenticated() && request.auth.uid == inspectorId;
    }

    function isAdmin() {
      return isAuthenticated() &&
        (get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin' ||
          (request.auth.token.email == "qdezimoveis@gmail.com" && request.auth.token.email_verified == true));
    }

    function isValidUser(data) {
      return data.keys().hasAll(['uid', 'email', 'role']) &&
             data.uid is string && data.uid.size() > 0 &&
             data.email is string && data.email.size() > 0 &&
             data.role in ['inspector', 'admin'];
    }

    function isValidProperty(data) {
      return data.keys().hasAll(['address', 'inspectorId', 'createdAt']) &&
             data.address is string && data.address.size() > 0 && data.address.size() < 500 &&
             data.inspectorId is string &&
             data.createdAt is timestamp &&
             (!('price' in data) || data.price is number) &&
             (!('size' in data) || data.size is number) &&
             (!('bedrooms' in data) || data.bedrooms is number) &&
             (!('bathrooms' in data) || data.bathrooms is number);
    }

    function isValidFavorite(data) {
      return data.keys().hasAll(['userId', 'propertyId', 'createdAt']) &&
             data.userId == request.auth.uid &&
             data.propertyId is string &&
             data.createdAt is timestamp;
    }

    function isValidInspection(data) {
      return data.keys().hasAll(['propertyId', 'type', 'status', 'inspectorId', 'date']) &&
             data.propertyId is string &&
             data.type in ['Entry', 'Exit', 'Periodic'] &&
             data.status in ['Draft', 'Completed'] &&
             data.inspectorId is string &&
             data.date is timestamp;
    }

    function isValidRoom(data) {
      return data.keys().hasAll(['inspectionId', 'name', 'order']) &&
             data.inspectionId is string &&
             data.name is string && data.name.size() > 0 && data.name.size() < 100 &&
             data.order is number &&
             (!('notes' in data) || data.notes is string) &&
             (!('media' in data) || data.media is list) &&
             (!('aiAnalysis' in data) || data.aiAnalysis is string);
    }

    function isValidItem(data) {
      return data.keys().hasAll(['roomId', 'name', 'status']) &&
             data.roomId is string &&
             data.name is string && data.name.size() > 0 && data.name.size() < 100 &&
             data.status in ['Good', 'Regular', 'Bad', 'N/A'];
    }

    // ===============================================================
    // Collection Rules
    // ===============================================================

    match /users/{userId} {
      allow read: if isOwner(userId) || isAdmin();
      allow create: if isAuthenticated() && isValidUser(request.resource.data) && (isOwner(userId) || isAdmin());
      allow update: if isAuthenticated() && isValidUser(request.resource.data) && (isOwner(userId) || isAdmin());
    }

    match /favorites/{favoriteId} {
      allow read: if isAuthenticated() && (resource.data.userId == request.auth.uid || isAdmin());
      allow create: if isAuthenticated() && isValidFavorite(request.resource.data);
      allow delete: if isAuthenticated() && (resource.data.userId == request.auth.uid || isAdmin());
    }

    match /properties/{propertyId} {
      allow read: if isAuthenticated() && (resource.data.inspectorId == request.auth.uid || isAdmin());
      allow create: if isAuthenticated() && isValidProperty(request.resource.data) && (request.resource.data.inspectorId == request.auth.uid || isAdmin());
      allow update: if isAuthenticated() && isValidProperty(request.resource.data) && (resource.data.inspectorId == request.auth.uid || isAdmin());
      allow delete: if isAuthenticated() && (resource.data.inspectorId == request.auth.uid || isAdmin());
    }

    match /inspections/{inspectionId} {
      allow read: if isAuthenticated() && (resource.data.inspectorId == request.auth.uid || isAdmin());
      allow create: if isAuthenticated() && isValidInspection(request.resource.data) && (request.resource.data.inspectorId == request.auth.uid || isAdmin());
      allow update: if isAuthenticated() && isValidInspection(request.resource.data) && (resource.data.inspectorId == request.auth.uid || isAdmin());
      allow delete: if isAuthenticated() && (resource.data.inspectorId == request.auth.uid || isAdmin());
    }

    match /rooms/{roomId} {
      allow read: if isAuthenticated() && (get(/databases/$(database)/documents/inspections/$(resource.data.inspectionId)).data.inspectorId == request.auth.uid || isAdmin());
      allow create: if isAuthenticated() && isValidRoom(request.resource.data) && (get(/databases/$(database)/documents/inspections/$(request.resource.data.inspectionId)).data.inspectorId == request.auth.uid || isAdmin());
      allow update: if isAuthenticated() && isValidRoom(request.resource.data) && (get(/databases/$(database)/documents/inspections/$(resource.data.inspectionId)).data.inspectorId == request.auth.uid || isAdmin());
      allow delete: if isAuthenticated() && (get(/databases/$(database)/documents/inspections/$(resource.data.inspectionId)).data.inspectorId == request.auth.uid || isAdmin());
    }

    match /media/{mediaId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated();
      allow update: if isAuthenticated();
      allow delete: if isAuthenticated();
    }

    match /items/{itemId} {
      allow read: if isAuthenticated(); // Scoped by roomId in queries, but could be tightened
      allow create: if isAuthenticated() && isValidItem(request.resource.data);
      allow update: if isAuthenticated() && isValidItem(request.resource.data);
      allow delete: if isAuthenticated();
    }
  }
}
